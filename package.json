{
  "name": "omnifs",
  "version": "0.1.0",
  "description": "A single read()/write() call that works for any file format, any JS runtime, any environment",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.mts",
        "default": "./dist/react.mjs"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue.d.mts",
        "default": "./dist/vue.mjs"
      },
      "require": {
        "types": "./dist/vue.d.cts",
        "default": "./dist/vue.cjs"
      }
    },
    "./svelte": {
      "import": {
        "types": "./dist/svelte.d.mts",
        "default": "./dist/svelte.mjs"
      },
      "require": {
        "types": "./dist/svelte.d.cts",
        "default": "./dist/svelte.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.*"
  ],
  "scripts": {
    "build": "tsup && node -e \"const{copyFileSync}=require('fs');['index','react','vue','svelte'].forEach(n=>copyFileSync('dist/'+n+'.d.ts','dist/'+n+'.d.mts'))\"",
    "test": "vitest run",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "check-exports": "publint && attw --pack . --profile node16"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "file",
    "read",
    "write",
    "csv",
    "json",
    "xml",
    "universal",
    "esm",
    "cjs"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.8",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
